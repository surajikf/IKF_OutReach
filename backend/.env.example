# Backend runtime
DATABASE_URL=postgresql://user:pass@host:5432/dbname
DIRECT_URL=

# Supabase SSR/Auth
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Public browser URL used in OAuth callbacks and redirects
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# Crypto / secret management
STRATEGIC_SECRET=change-this-to-a-secure-random-string

# Optional provider fallbacks
GROQ_API_KEY=
OPENAI_API_KEY=

# External integrations
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
INVOICE_API_URL=http://localhost/invoice/api/ApiService.asmx
INVOICE_API_KEY=

NODE_ENV=production
