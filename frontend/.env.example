# Frontend runtime
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public browser URL for the frontend
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional when hosting the frontend under a virtual directory, e.g. /ikf-outreach
NEXT_PUBLIC_BASE_PATH=

# Optional local proxy target. Leave empty in production when IIS/Nginx already forwards /api to backend.
BACKEND_INTERNAL_URL=http://localhost:3001
