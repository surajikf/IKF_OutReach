# App runtime
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=

# Public browser URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-secret

# Google OAuth (Google Cloud Console > Credentials > OAuth 2.0 Client ID)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional when hosting the frontend under a virtual directory, e.g. /ikf-outreach
NEXT_PUBLIC_BASE_PATH=

# Database (required)
DATABASE_URL=postgresql://user:pass@host:5432/dbname
DIRECT_URL=postgresql://user:pass@host:5432/dbname

# Server encryption / secrets (required)
STRATEGIC_SECRET=change-this-to-a-secure-random-string
ENCRYPTION_KEY=change-this-to-a-secure-random-string
ENCRYPTION_IV=change-this-to-a-secure-random-string

# Optional provider fallbacks
GROQ_API_KEY=
OPENAI_API_KEY=
BREVO_API_KEY=

# Optional diagnostics
AUTH_DEBUG=false
NEXTAUTH_DEBUG=false
